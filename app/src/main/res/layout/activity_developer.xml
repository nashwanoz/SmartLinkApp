<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layoutDirection="rtl"
    android:gravity="center"
    android:padding="24dp">

    <!-- اسم البرنامج وحالته -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="برنامج سمارت لينك"
        android:textColor="#0D47A1"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الجيل القادم من الأتمتة المحاسبية"
        android:textColor="#546E7A"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <!-- نوع التوزيعة والنسخة -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الاصدار التجريبي"
        android:textColor="#C62828"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="#FFEBEE"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginBottom="48dp"/>

    <!-- معلومات المطور الشخصية -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="المطور: نشوان العديني"
        android:textColor="#37474F"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞 776323844"
        android:textColor="#1565C0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"/>
</LinearLayout>
